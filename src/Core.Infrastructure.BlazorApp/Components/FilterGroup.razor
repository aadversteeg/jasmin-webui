<div class="filter-group">
    <div class="filter-group-header">
        <span class="filter-group-title">@Title</span>
        @if (OnSelectAll != null || OnDeselectAll != null)
        {
            <div class="filter-actions">
                @if (OnSelectAll != null)
                {
                    <button type="button" class="btn btn-sm btn-link filter-action-btn small" @onclick="OnSelectAll">
                        All
                    </button>
                }
                @if (OnSelectAll != null && OnDeselectAll != null)
                {
                    <span class="text-muted small">|</span>
                }
                @if (OnDeselectAll != null)
                {
                    <button type="button" class="btn btn-sm btn-link filter-action-btn small" @onclick="OnDeselectAll">
                        None
                    </button>
                }
            </div>
        }
    </div>
    <div class="filter-group-items">
        @foreach (var item in Items)
        {
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       id="@item.Id"
                       checked="@item.IsSelected"
                       @onchange="@(e => item.OnSelectionChanged((bool)(e.Value ?? false)))" />
                <label class="form-check-label @(item.IsDeleted ? "deleted-item" : "")" for="@item.Id">
                    <span class="filter-item-content">
                        <span>@item.Label</span>
                        @if (item.IsDeleted)
                        {
                            <span class="deleted-indicator">deleted</span>
                        }
                    </span>
                </label>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public IEnumerable<FilterPanelItem> Items { get; set; } = Enumerable.Empty<FilterPanelItem>();

    [Parameter]
    public Action? OnSelectAll { get; set; }

    [Parameter]
    public Action? OnDeselectAll { get; set; }
}
