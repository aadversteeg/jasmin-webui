@using Core.Application.McpServers

<article class="expandable-card @(IsExpanded ? "expanded" : "")" @onclick="HandleClick">
    <div class="card-header-row">
        <div>
            <code class="item-name">@Name</code>
            @if (!string.IsNullOrEmpty(Title) && Title != Name)
            {
                <span class="text-muted item-title">@Title</span>
            }
        </div>
        <div class="card-header-actions">
            @HeaderActions
            <button type="button"
                    class="expand-icon btn-unstyled"
                    aria-expanded="@IsExpanded.ToString().ToLowerInvariant()"
                    aria-label="@(IsExpanded ? "Collapse details" : "Expand details")"
                    @onclick="HandleClick"
                    @onclick:stopPropagation="true">
                @(IsExpanded ? "\u25B2" : "\u25BC")
            </button>
        </div>
    </div>
    @if (!IsExpanded && !string.IsNullOrEmpty(Description))
    {
        <div class="text-muted small description-preview">
            @TruncateDescription(Description)
        </div>
    }

    @if (IsExpanded)
    {
        <div class="item-details" @onclick:stopPropagation="true">
            @if (!string.IsNullOrEmpty(Description))
            {
                <p class="text-muted small item-description">@Description</p>
            }
            @ChildContent
        </div>
    }
</article>

@code {
    [Parameter]
    public required string Name { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public bool IsExpanded { get; set; }

    [Parameter]
    public EventCallback OnToggle { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? HeaderActions { get; set; }

    private async Task HandleClick()
    {
        await OnToggle.InvokeAsync();
    }

    private string TruncateDescription(string description)
    {
        const int maxLength = 100;
        if (description.Length <= maxLength) return description;
        return description[..maxLength] + "...";
    }
}
