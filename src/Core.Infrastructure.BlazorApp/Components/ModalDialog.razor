@inject IJSRuntime JS
@implements IDisposable

<dialog class="modal-dialog-element" style="@GetDialogStyle()" @ref="_dialogRef">
    <div class="modal-content" style="@GetContentStyle()">
        <div class="modal-header">
            <h5 class="modal-title">@Title</h5>
            <button type="button" class="btn-close" @onclick="HandleClose" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="@GetBodyStyle()">
            @ChildContent
        </div>
        <div class="modal-footer">
            @FooterContent
        </div>
    </div>
</dialog>

@code {
    private ElementReference _dialogRef;
    private DotNetObjectReference<ModalDialog>? _dotNetRef;
    private bool _wasOpen;
    private bool _jsInitialized;

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int MaxWidth { get; set; } = 500;
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public string? MinWidth { get; set; }
    [Parameter] public string? MinHeight { get; set; }
    [Parameter] public bool Resizable { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string GetDialogStyle()
    {
        var styles = new List<string>();

        if (!string.IsNullOrEmpty(Width))
        {
            styles.Add($"width: {Width}");
            if (!Resizable)
            {
                styles.Add($"max-width: {Width}");
            }
        }
        else if (!Resizable)
        {
            styles.Add($"max-width: {MaxWidth}px");
        }

        if (!string.IsNullOrEmpty(Height))
        {
            styles.Add($"height: {Height}");
        }

        if (!string.IsNullOrEmpty(MinWidth))
        {
            styles.Add($"min-width: {MinWidth}");
        }

        if (!string.IsNullOrEmpty(MinHeight))
        {
            styles.Add($"min-height: {MinHeight}");
        }

        if (Resizable)
        {
            styles.Add("resize: horizontal");
            styles.Add("overflow: hidden");
        }

        return string.Join("; ", styles);
    }

    private string GetContentStyle()
    {
        if (!string.IsNullOrEmpty(Height))
        {
            return "height: 100%; display: flex; flex-direction: column;";
        }
        return "";
    }

    private string GetBodyStyle()
    {
        if (!string.IsNullOrEmpty(Height))
        {
            return "flex: 1; overflow-y: auto;";
        }
        return "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("dialogHelper.init", _dialogRef, _dotNetRef);
            _jsInitialized = true;
        }

        if (!_jsInitialized) return;

        if (IsOpen && !_wasOpen)
        {
            _wasOpen = true;
            await JS.InvokeVoidAsync("dialogHelper.showModal", _dialogRef);
        }
        else if (!IsOpen && _wasOpen)
        {
            _wasOpen = false;
            await JS.InvokeVoidAsync("dialogHelper.close", _dialogRef);
        }
    }

    [JSInvokable]
    public async Task OnDialogCancel()
    {
        await OnClose.InvokeAsync();
    }

    [JSInvokable]
    public async Task OnDialogBackdropClick()
    {
        await OnClose.InvokeAsync();
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
