<section class="filter-panel">
    <div class="filter-panel-header"
         @onclick="ToggleExpanded"
         @onkeydown="HandleHeaderKeyDown"
         role="button"
         tabindex="0"
         aria-expanded="@IsExpanded.ToString().ToLowerInvariant()">
        <div class="filter-panel-heading">
            <span class="expand-icon" aria-hidden="true">@(IsExpanded ? "▼" : "▶")</span>
            <span class="filter-panel-title">@Title</span>
        </div>
        <div class="filter-actions" @onclick:stopPropagation="true">
            <button type="button" class="btn btn-sm btn-link filter-action-btn" @onclick="OnSelectAll" title="Select all">
                All
            </button>
            <span class="text-muted">|</span>
            <button type="button" class="btn btn-sm btn-link filter-action-btn" @onclick="OnDeselectAll" title="Deselect all">
                None
            </button>
        </div>
    </div>

    @if (IsExpanded)
    {
        <div class="filter-panel-body">
            @if (Groups.Count() > 1)
            {
                @foreach (var group in Groups)
                {
                    <FilterGroup Title="@group.Name"
                                 Items="@group.Items"
                                 OnSelectAll="@group.OnSelectAll"
                                 OnDeselectAll="@group.OnDeselectAll" />
                }
            }
            else
            {
                @* Single group or no groups - render flat list without headers *@
                @foreach (var item in Groups.SelectMany(g => g.Items))
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               id="@item.Id"
                               checked="@item.IsSelected"
                               @onchange="@(e => item.OnSelectionChanged((bool)(e.Value ?? false)))" />
                        <label class="form-check-label @(item.IsDeleted ? "deleted-item" : "")" for="@item.Id">
                            <span class="filter-item-content">
                                <span>@item.Label</span>
                                @if (item.IsDeleted)
                                {
                                    <span class="deleted-indicator">deleted</span>
                                }
                            </span>
                        </label>
                    </div>
                }
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public bool IsExpanded { get; set; } = true;

    [Parameter]
    public EventCallback<bool> IsExpandedChanged { get; set; }

    [Parameter]
    public EventCallback OnSelectAll { get; set; }

    [Parameter]
    public EventCallback OnDeselectAll { get; set; }

    [Parameter]
    public IEnumerable<FilterPanelGroup> Groups { get; set; } = Enumerable.Empty<FilterPanelGroup>();

    private async Task ToggleExpanded()
    {
        IsExpanded = !IsExpanded;
        await IsExpandedChanged.InvokeAsync(IsExpanded);
    }

    private async Task HandleHeaderKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
        {
            await ToggleExpanded();
        }
    }
}
